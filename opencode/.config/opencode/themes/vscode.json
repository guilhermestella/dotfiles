{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#1f1f1f",
    "bg_mid": "#252526",
    "bg_subtle": "#333333",
    "fg": "#d4d4d4",
    "fg_muted": "#4a8cb5",
    "comment": "#4a8cb5",
    "green": "#6a9955",
    "blue": "#569cd6",
    "red": "#f44747",
    "yellow": "#dcdcaa",
    "orange": "#ce9178",
    "teal": "#4ec9b0",
    "light_blue": "#9cdcfe",
    "cyan": "#4fc1ff"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "cyan"
    },
    "secondary": {
      "dark": "teal",
      "light": "teal"
    },
    "accent": {
      "dark": "light_blue",
      "light": "light_blue"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
    },
    "success": {
      "dark": "blue",
      "light": "blue"
    },
    "info": {
      "dark": "cyan",
      "light": "cyan"
    },
    "text": {
      "dark": "fg",
      "light": "fg"
    },
    "textMuted": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "background": {
      "dark": "bg",
      "light": "bg"
    },
    "backgroundPanel": {
      "dark": "bg_mid",
      "light": "bg_mid"
    },
    "backgroundElement": {
      "dark": "bg_subtle",
      "light": "bg_subtle"
    },
    "border": {
      "dark": "bg_subtle",
      "light": "bg_subtle"
    },
    "borderActive": {
      "dark": "blue",
      "light": "blue"
    },
    "diffAdded": {
      "dark": "teal",
      "light": "teal"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffContext": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "comment"
    },
    "syntaxKeyword": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxFunction": {
      "dark": "yellow",
      "light": "yellow"
    },
    "syntaxVariable": {
      "dark": "light_blue",
      "light": "light_blue"
    },
    "syntaxString": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxNumber": {
      "dark": "teal",
      "light": "teal"
    },
    "syntaxType": {
      "dark": "teal",
      "light": "teal"
    },
    "syntaxOperator": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "fg"
    },
    "markdownCode": {
      "dark": "orange",
      "light": "orange"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "fg"
    }
  }
}
